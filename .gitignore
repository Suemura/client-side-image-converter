# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/.wrangler

# sitemap
/public/sitemap*.xml
/public/robots.txt

# Claude Code の個人設定（共有しない）
.claude/settings.local.json

# Claude Code のセッション用 worktree（/start-issue 等が作成）
.claude/worktrees/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# C2PA WASM（predev / prebuild で node_modules からコピーされる）
/public/c2pa/
