{
  "name": "client-side-image-converter",
  "author": "Masato Suemura",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Suemura/client-side-image-converter"
  },
  "homepage": "https://image-converter.suemura.app/",
  "keywords": [
    "image-converter",
    "privacy-first",
    "browser-based",
    "nextjs",
    "typescript",
    "webp",
    "jpeg",
    "png"
  ],
  "private": false,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "npx @biomejs/biome check src/",
    "lint:fix": "npx @biomejs/biome check src/ --write --unsafe",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "deploy": "npm run build && wrangler pages deploy out",
    "preview": "wrangler pages dev out"
  },
  "dependencies": {
    "exif-js": "^2.3.0",
    "heic-decode": "^2.1.0",
    "i18next": "^25.10.9",
    "jszip": "^3.10.1",
    "next": "^15.3.5",
    "pako": "^2.1.0",
    "piexifjs": "^1.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.6.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.61.1",
    "@types/exif-js": "^2.3.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^26",
    "@types/pako": "^2.0.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.30.1",
    "eslint-config-next": "^16.2.10",
    "happy-dom": "^20.10.6",
    "next-sitemap": "^4.2.3",
    "serve": "^14.2.6",
    "typescript": "^6",
    "vitest": "^4.1.9",
    "wrangler": "^4.24.3"
  }
}
