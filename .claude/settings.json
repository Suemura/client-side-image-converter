{
  "permissions": {
    "deny": [
      "Bash(sudo *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * --force)",
      "Bash(git push * --force *)",
      "Bash(git push * -f)",
      "Bash(git push * -f *)",
      "Read(.env*)",
      "Edit(.env*)",
      "Write(.env*)",
      "Read(.dev.vars*)",
      "Edit(.dev.vars*)",
      "Write(.dev.vars*)"
    ],
    "ask": [
      "Bash(gh pr merge)",
      "Bash(gh pr merge *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean)",
      "Bash(git clean *)",
      "Bash(npm run deploy)",
      "Bash(npm run deploy *)",
      "Bash(wrangler pages deploy *)",
      "Bash(npx wrangler pages deploy *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.ts|*.tsx|*.js|*.jsx|*.json|*.css) npx @biomejs/biome check --write \"$f\" 2>/dev/null || true;; esac; }",
            "timeout": 30,
            "statusMessage": "Biome でフォーマット中..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(gh pr create*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pr-created.sh\"",
            "timeout": 15,
            "statusMessage": "PR 作成を検知..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-on-stop.sh\"",
            "timeout": 300,
            "statusMessage": "lint / typecheck / test を実行中..."
          }
        ]
      }
    ]
  }
}
